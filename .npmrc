@fern-fern:registry=https://npm.buildwithfern.com
# pnpm 11+ runs runDepsStatusCheck before every script, which spawns a
# corepack-managed pnpm fetch. The npm registry's pnpm signing key has
# rotated past what older corepack builds trust, so the check throws
# `Cannot find matching keyid`. Disabling the pre-script check sidesteps
# the corepack signature verification entirely. Doesn't affect normal
# `pnpm install` invocations, only the implicit deps-check pnpm 11 does
# before running scripts. See discussion in
# automation/tournament/runs/r01/notes.md for the diagnosis trail.
verify-deps-before-run=false
